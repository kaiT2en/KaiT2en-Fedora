From 28b0ff60297c4863eee67aa9fba7ed6298471103 Mon Sep 17 00:00:00 2001
From: Andre Eikmeyer <andre.eikmeyer@gmail.com>
Date: Sat, 4 Jul 2026 14:53:44 +0200
Subject: [PATCH 1/2] platform/x86: apple-gmux: add display handoff helpers

---
 drivers/platform/x86/apple-gmux.c | 83 +++++++++++++++++++++++++++++++
 include/linux/apple-gmux.h        | 41 +++++++++++++++
 2 files changed, 124 insertions(+)

diff --git a/drivers/platform/x86/apple-gmux.c b/drivers/platform/x86/apple-gmux.c
index fbc30f1..bc9338c 100644
--- a/drivers/platform/x86/apple-gmux.c
+++ b/drivers/platform/x86/apple-gmux.c
@@ -22,6 +22,7 @@
 #include <linux/pci.h>
 #include <linux/vga_switcheroo.h>
 #include <linux/debugfs.h>
+#include <linux/mutex.h>
 #include <acpi/video.h>
 #include <asm/io.h>
 
@@ -69,6 +70,7 @@ struct apple_gmux_data {
 	acpi_handle dhandle;
 	int gpe;
 	bool external_switchable;
+	bool display_switchable;
 	enum vga_switcheroo_client_id switch_state_display;
 	enum vga_switcheroo_client_id switch_state_ddc;
 	enum vga_switcheroo_client_id switch_state_external;
@@ -78,6 +80,9 @@ struct apple_gmux_data {
 	/* debugfs data */
 	u8 selected_port;
 	struct dentry *debug_dentry;
+
+	/* Protects display switch save/restore operations. */
+	struct mutex switch_lock;
 };
 
 static struct apple_gmux_data *apple_gmux_data;
@@ -470,16 +475,91 @@ static void gmux_write_switch_state(struct apple_gmux_data *gmux_data)
 
 static int gmux_switchto(enum vga_switcheroo_client_id id)
 {
+	mutex_lock(&apple_gmux_data->switch_lock);
 	apple_gmux_data->switch_state_ddc = id;
 	apple_gmux_data->switch_state_display = id;
 	if (apple_gmux_data->external_switchable)
 		apple_gmux_data->switch_state_external = id;
 
 	gmux_write_switch_state(apple_gmux_data);
+	mutex_unlock(&apple_gmux_data->switch_lock);
 
 	return 0;
 }
 
+bool apple_gmux_switch_display(enum vga_switcheroo_client_id id,
+			       enum vga_switcheroo_client_id *old)
+{
+	struct apple_gmux_data *gmux_data = apple_gmux_data;
+	enum vga_switcheroo_client_id old_display;
+
+	if (!gmux_data || !gmux_data->display_switchable)
+		return false;
+
+	mutex_lock(&gmux_data->switch_lock);
+	gmux_read_switch_state(gmux_data);
+	old_display = gmux_data->switch_state_display;
+
+	if (old)
+		*old = old_display;
+
+	if (old_display != id) {
+		gmux_data->switch_state_display = id;
+		gmux_write_switch_state(gmux_data);
+		gmux_read_switch_state(gmux_data);
+	}
+
+	mutex_unlock(&gmux_data->switch_lock);
+
+	return true;
+}
+EXPORT_SYMBOL_GPL(apple_gmux_switch_display);
+
+void apple_gmux_restore_display(enum vga_switcheroo_client_id old,
+				enum vga_switcheroo_client_id expected)
+{
+	struct apple_gmux_data *gmux_data = apple_gmux_data;
+	enum vga_switcheroo_client_id old_display;
+
+	if (!gmux_data || !gmux_data->display_switchable)
+		return;
+
+	mutex_lock(&gmux_data->switch_lock);
+	gmux_read_switch_state(gmux_data);
+	old_display = gmux_data->switch_state_display;
+
+	if (old_display == expected && old_display != old) {
+		gmux_data->switch_state_display = old;
+		gmux_write_switch_state(gmux_data);
+		gmux_read_switch_state(gmux_data);
+	}
+
+	mutex_unlock(&gmux_data->switch_lock);
+}
+EXPORT_SYMBOL_GPL(apple_gmux_restore_display);
+
+void apple_gmux_reset_display_link(void)
+{
+	struct apple_gmux_data *gmux_data = apple_gmux_data;
+
+	if (!gmux_data || !gmux_data->display_switchable)
+		return;
+
+	mutex_lock(&gmux_data->switch_lock);
+	gmux_read_switch_state(gmux_data);
+
+	gmux_data->switch_state_display = VGA_SWITCHEROO_IGD;
+	gmux_write_switch_state(gmux_data);
+	mdelay(200);
+	gmux_data->switch_state_display = VGA_SWITCHEROO_DIS;
+	gmux_write_switch_state(gmux_data);
+	mdelay(200);
+	gmux_read_switch_state(gmux_data);
+
+	mutex_unlock(&gmux_data->switch_lock);
+}
+EXPORT_SYMBOL_GPL(apple_gmux_reset_display_link);
+
 static int gmux_switch_ddc(enum vga_switcheroo_client_id id)
 {
 	enum vga_switcheroo_client_id old_ddc_owner =
@@ -807,6 +887,7 @@ static int gmux_probe(struct pnp_dev *pnp, const struct pnp_device_id *id)
 	switch (type) {
 	case APPLE_GMUX_TYPE_MMIO:
 		gmux_data->config = &apple_gmux_mmio;
+		gmux_data->display_switchable = true;
 		mutex_init(&gmux_data->index_lock);
 
 		res = pnp_get_resource(pnp, IORESOURCE_MEM, 0);
@@ -826,6 +907,7 @@ static int gmux_probe(struct pnp_dev *pnp, const struct pnp_device_id *id)
 		goto get_version;
 	case APPLE_GMUX_TYPE_INDEXED:
 		gmux_data->config = &apple_gmux_index;
+		gmux_data->display_switchable = true;
 		mutex_init(&gmux_data->index_lock);
 		break;
 	case APPLE_GMUX_TYPE_PIO:
@@ -942,6 +1024,7 @@ static int gmux_probe(struct pnp_dev *pnp, const struct pnp_device_id *id)
 
 	apple_gmux_data = gmux_data;
 	init_completion(&gmux_data->powerchange_done);
+	mutex_init(&gmux_data->switch_lock);
 	gmux_enable_interrupts(gmux_data);
 	gmux_read_switch_state(gmux_data);
 
diff --git a/include/linux/apple-gmux.h b/include/linux/apple-gmux.h
index 206d97f..4829123 100644
--- a/include/linux/apple-gmux.h
+++ b/include/linux/apple-gmux.h
@@ -10,6 +10,7 @@
 #include <linux/acpi.h>
 #include <linux/io.h>
 #include <linux/pnp.h>
+#include <linux/vga_switcheroo.h>
 
 #define GMUX_ACPI_HID "APP000B"
 
@@ -163,6 +164,30 @@ static inline bool apple_gmux_present(void)
 	return acpi_dev_found(GMUX_ACPI_HID);
 }
 
+#if IS_REACHABLE(CONFIG_APPLE_GMUX)
+bool apple_gmux_switch_display(enum vga_switcheroo_client_id id,
+			       enum vga_switcheroo_client_id *old);
+void apple_gmux_restore_display(enum vga_switcheroo_client_id old,
+				enum vga_switcheroo_client_id expected);
+void apple_gmux_reset_display_link(void);
+#else
+static inline bool apple_gmux_switch_display(enum vga_switcheroo_client_id id,
+					     enum vga_switcheroo_client_id *old)
+{
+	return false;
+}
+
+static inline void
+apple_gmux_restore_display(enum vga_switcheroo_client_id old,
+			   enum vga_switcheroo_client_id expected)
+{
+}
+
+static inline void apple_gmux_reset_display_link(void)
+{
+}
+#endif
+
 #else  /* !CONFIG_APPLE_GMUX */
 
 static inline bool apple_gmux_present(void)
@@ -175,6 +200,22 @@ static inline bool apple_gmux_detect(struct pnp_dev *pnp_dev, bool *indexed_ret)
 	return false;
 }
 
+static inline bool apple_gmux_switch_display(enum vga_switcheroo_client_id id,
+					     enum vga_switcheroo_client_id *old)
+{
+	return false;
+}
+
+static inline void
+apple_gmux_restore_display(enum vga_switcheroo_client_id old,
+			   enum vga_switcheroo_client_id expected)
+{
+}
+
+static inline void apple_gmux_reset_display_link(void)
+{
+}
+
 #endif /* !CONFIG_APPLE_GMUX */
 
 #endif /* LINUX_APPLE_GMUX_H */
-- 
2.54.0

