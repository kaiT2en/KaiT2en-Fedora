From ce19c2e1f275c4e27210ebb994374e182e71a59a Mon Sep 17 00:00:00 2001
From: Andre Eikmeyer <dev@deq.rocks>
Date: Wed, 22 Jul 2026 01:04:44 +0200
Subject: [PATCH] thunderbolt: Apple T2 systems need resume ordering links

Apple T2 Macs lose their Thunderbolt PCIe tunnels during S3. The NHI
must resume before the tunneled downstream ports so it can rebuild those
tunnels before their consumers resume.

The driver already establishes this ordering on older Apple Thunderbolt
controllers. Titan Ridge uses the same discrete switch topology, but its
NHI IDs are absent from the Apple-specific match.

Ice Lake T2 Macs use integrated NHIs instead. Their firmware describes
the tunneled native root ports with ACPI bus IDs beginning with "TRP",
but without the usb4-host-interface references consumed by the generic
ACPI link discovery. The driver consequently reports that the links are
missing. The Apple-specific path can associate those root ports with an
Ice Lake NHI by their shared PCI domain and bus.

The missing ordering leaves bridges waiting for several seconds during
resume and also delays secondary CPU bring-up. Repeated S3 cycles on a
MacBookPro15,1 reduced CPU bring-up from 12-15 seconds to about one
second once the complete T2 suspend fix was active. The Ice Lake layout
and missing generic links were confirmed on a MacBookAir9,1.

Signed-off-by: Andre Eikmeyer <dev@deq.rocks>
---
 drivers/thunderbolt/tb.c | 42 ++++++++++++++++++++++++++++++++++++++++
 1 file changed, 42 insertions(+)

diff --git a/drivers/thunderbolt/tb.c b/drivers/thunderbolt/tb.c
index 76323255439a..99f22fed462c 100644
--- a/drivers/thunderbolt/tb.c
+++ b/drivers/thunderbolt/tb.c
@@ -9,6 +9,7 @@
 #include <linux/slab.h>
 #include <linux/errno.h>
 #include <linux/delay.h>
+#include <linux/acpi.h>
 #include <linux/pm_runtime.h>
 #include <linux/platform_data/x86/apple.h>
 
@@ -3309,6 +3310,42 @@ static const struct tb_cm_ops tb_cm_ops = {
  * downstream ports and the NHI so that the device core will make sure
  * NHI is resumed first before the rest.
  */
+static bool tb_apple_add_icl_links(struct tb_nhi *nhi)
+{
+	struct pci_dev *nhi_pdev = to_pci_dev(nhi->dev);
+	struct pci_dev *pdev = NULL;
+	bool ret = false;
+
+	for_each_pci_dev(pdev) {
+		struct acpi_device *adev = ACPI_COMPANION(&pdev->dev);
+		const struct device_link *link;
+		const char *bid;
+
+		if (pci_domain_nr(pdev->bus) != pci_domain_nr(nhi_pdev->bus) ||
+		    pdev->bus != nhi_pdev->bus || !pci_is_pcie(pdev) ||
+		    pci_pcie_type(pdev) != PCI_EXP_TYPE_ROOT_PORT || !adev)
+			continue;
+
+		bid = acpi_device_bid(adev);
+		if (!bid || strncmp(bid, "TRP", 3))
+			continue;
+
+		link = device_link_add(&pdev->dev, nhi->dev,
+				       DL_FLAG_AUTOREMOVE_SUPPLIER |
+				       DL_FLAG_PM_RUNTIME);
+		if (link) {
+			dev_dbg(nhi->dev, "created link from %s\n",
+				dev_name(&pdev->dev));
+			ret = true;
+		} else {
+			dev_warn(nhi->dev, "device link creation from %s failed\n",
+				 dev_name(&pdev->dev));
+		}
+	}
+
+	return ret;
+}
+
 static bool tb_apple_add_links(struct tb_nhi *nhi)
 {
 	struct pci_dev *nhi_pdev = to_pci_dev(nhi->dev);
@@ -3319,10 +3356,15 @@ static bool tb_apple_add_links(struct tb_nhi *nhi)
 		return false;
 
 	switch (nhi_pdev->device) {
+	case PCI_DEVICE_ID_INTEL_ICL_NHI0:
+	case PCI_DEVICE_ID_INTEL_ICL_NHI1:
+		return tb_apple_add_icl_links(nhi);
 	case PCI_DEVICE_ID_INTEL_LIGHT_RIDGE:
 	case PCI_DEVICE_ID_INTEL_CACTUS_RIDGE_4C:
 	case PCI_DEVICE_ID_INTEL_FALCON_RIDGE_2C_NHI:
 	case PCI_DEVICE_ID_INTEL_FALCON_RIDGE_4C_NHI:
+	case PCI_DEVICE_ID_INTEL_TITAN_RIDGE_2C_NHI:
+	case PCI_DEVICE_ID_INTEL_TITAN_RIDGE_4C_NHI:
 		break;
 	default:
 		return false;
-- 
