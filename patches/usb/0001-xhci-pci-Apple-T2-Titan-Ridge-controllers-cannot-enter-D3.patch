From cc7f189b5f0ba0531345e5e532e4dc680f51d6cd Mon Sep 17 00:00:00 2001
From: Andre Eikmeyer <dev@deq.rocks>
Date: Wed, 22 Jul 2026 01:08:07 +0200
Subject: [PATCH] xhci: pci: Apple T2 Titan Ridge controllers cannot enter D3

The Titan Ridge xHCI path in Apple T2 Macs does not resume reliably after
entering D3. Its upstream bridge stalls for about five seconds in
pci_pm_resume_noirq(), while the controller reports USBSTS 0x401 and is
subsequently reinitialized by the existing recovery path.

The endpoint and its immediate downstream port remain usable in D0 across
S3 without increasing measured suspend power on a MacBookPro15,1. Both
devices therefore need PCI_DEV_FLAGS_NO_D3 on T2 systems.

Together with the Thunderbolt device links, repeated S3 cycles reduced
the two bridge resume callbacks from about 5.3 seconds each to less than
100 microseconds.

Signed-off-by: Andre Eikmeyer <dev@deq.rocks>
---
 drivers/usb/host/xhci-pci.c | 31 +++++++++++++++++++++++++++++++
 1 file changed, 31 insertions(+)

diff --git a/drivers/usb/host/xhci-pci.c b/drivers/usb/host/xhci-pci.c
index 039c26b241d0..b9d205d781d4 100644
--- a/drivers/usb/host/xhci-pci.c
+++ b/drivers/usb/host/xhci-pci.c
@@ -14,6 +14,7 @@
 #include <linux/acpi.h>
 #include <linux/reset.h>
 #include <linux/suspend.h>
+#include <linux/platform_data/x86/apple.h>
 
 #include "xhci.h"
 #include "xhci-trace.h"
@@ -71,6 +72,8 @@
 #define PCI_DEVICE_ID_INTEL_TITAN_RIDGE_4C_XHCI		0x15ec
 #define PCI_DEVICE_ID_INTEL_TITAN_RIDGE_DD_XHCI		0x15f0
 
+#define PCI_DEVICE_ID_APPLE_T2_BRIDGE			0x1801
+
 #define PCI_DEVICE_ID_AMD_ARIEL_TYPEC_XHCI		0x13ed
 #define PCI_DEVICE_ID_AMD_ARIEL_TYPEA_XHCI		0x13ee
 #define PCI_DEVICE_ID_AMD_STARSHIP_XHCI			0x148c
@@ -248,6 +251,32 @@ static int xhci_pci_reinit(struct xhci_hcd *xhci, struct pci_dev *pdev)
 	return 0;
 }
 
+static void xhci_pci_apple_t2_quirks(struct pci_dev *pdev)
+{
+	struct pci_dev *bridge;
+	struct pci_dev *t2;
+
+	if (!x86_apple_machine || pdev->vendor != PCI_VENDOR_ID_INTEL)
+		return;
+
+	if (pdev->device != PCI_DEVICE_ID_INTEL_TITAN_RIDGE_2C_XHCI &&
+	    pdev->device != PCI_DEVICE_ID_INTEL_TITAN_RIDGE_4C_XHCI &&
+	    pdev->device != PCI_DEVICE_ID_INTEL_TITAN_RIDGE_DD_XHCI)
+		return;
+
+	t2 = pci_get_device(PCI_VENDOR_ID_APPLE, PCI_DEVICE_ID_APPLE_T2_BRIDGE,
+			    NULL);
+	if (!t2)
+		return;
+	pci_dev_put(t2);
+
+	/* The controller and its downstream port stall platform resume in D3. */
+	pdev->dev_flags |= PCI_DEV_FLAGS_NO_D3;
+	bridge = pci_upstream_bridge(pdev);
+	if (bridge)
+		bridge->dev_flags |= PCI_DEV_FLAGS_NO_D3;
+}
+
 static void xhci_pci_quirks(struct device *dev, struct xhci_hcd *xhci)
 {
 	struct pci_dev                  *pdev = to_pci_dev(dev);
@@ -511,6 +540,8 @@ static void xhci_pci_quirks(struct device *dev, struct xhci_hcd *xhci)
 	if (xhci->hci_version >= 0x120)
 		xhci->quirks |= XHCI_DEFAULT_PM_RUNTIME_ALLOW;
 
+	xhci_pci_apple_t2_quirks(pdev);
+
 	if (xhci->quirks & XHCI_RESET_ON_RESUME)
 		xhci_dbg_trace(xhci, trace_xhci_dbg_quirks,
 				"QUIRK: Resetting on resume");
-- 
